generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @db.VarChar(255)
  slug             String             @unique @db.VarChar(255)
  daily_challenges daily_challenges[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model daily_challenges {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  movie_id       Int?
  category_id    String?     @db.Uuid
  challenge_date DateTime    @db.Date
  categories     categories? @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  games          games[]

  @@unique([category_id, challenge_date])
  @@index([challenge_date], map: "idx_challenges_date")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model games {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String?           @db.Uuid
  challenge_id     String?           @db.Uuid
  is_won           Boolean?          @default(false)
  attempts         Int?              @default(0)
  points_earned    Int?              @default(0)
  played_at        DateTime?         @default(now()) @db.Timestamp(6)
  daily_challenges daily_challenges? @relation(fields: [challenge_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users?            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, challenge_id])
  @@index([challenge_id], map: "idx_games_challenge_id")
  @@index([user_id], map: "idx_games_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model movies {
  tmdb_id               Int       @id
  imdb_id               String?   @unique @db.VarChar(50)
  title                 String?   @db.VarChar(255)
  original_title        String?   @db.VarChar(255)
  original_language     String?   @db.VarChar(50)
  release_date          DateTime? @db.Date
  budget                BigInt?
  revenue               BigInt?
  poster_path           String?   @db.VarChar(255)
  backdrop_path         String?   @db.VarChar(255)
  overview              String?
  genres                Int[]
  production_companies  String[]
  director              String?   @db.VarChar(255)
  actors                String[]
  imdb_rating           String?   @db.VarChar(10)
  rotten_tomatoes_score Int?
  is_oscar_winner       Boolean?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_avatars {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String?   @db.Uuid
  movie_id     Int?
  purchased_at DateTime? @default(now()) @db.Timestamp(6)
  users        users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, movie_id])
  @@index([user_id], map: "idx_user_avatars_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username           String         @unique @db.VarChar(255)
  email              String         @unique @db.VarChar(255)
  password_hash      String         @db.VarChar(255)
  role               String?        @default("user") @db.VarChar(50)
  lifetime_points    Int?           @default(0)
  points_balance     Int?           @default(0)
  current_streak     Int?           @default(0)
  equipped_avatar_id Int?
  created_at         DateTime?      @default(now()) @db.Timestamp(6)
  games              games[]
  user_avatars       user_avatars[]
}
